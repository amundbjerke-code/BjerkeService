generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  EMPLOYEE
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
}

enum ProjectStatus {
  PLANLAGT
  PAGAR
  FERDIG
  FAKTURERT
}

enum ProjectBillingType {
  TIME
  FASTPRIS
}

enum OfferType {
  FASTPRIS
  TIMEBASERT
}

enum OfferStatus {
  UTKAST
  SENDT
  GODKJENT
  AVVIST
}

enum OfferHistoryAction {
  CREATED
  UPDATED
  STATUS_CHANGED
  CONVERTED_TO_PROJECT
}

enum ChecklistItemAnswer {
  JA
  NEI
  IKKE_RELEVANT
}

enum AvvikAlvorlighetsgrad {
  LAV
  MIDDELS
  HOY
  KRITISK
}

enum AvvikStatus {
  APENT
  UNDER_BEHANDLING
  LUKKET
}

enum MaterialStatus {
  TRENGS
  BESTILT
  MOTTATT
}

enum ProjectFinanceEntryType {
  UTGIFT
  TILLEGG
}

model User {
  id                        String               @id @default(cuid())
  name                      String
  email                     String               @unique
  passwordHash              String
  role                      Role                 @default(EMPLOYEE)
  createdAt                 DateTime             @default(now())
  updatedAt                 DateTime             @updatedAt
  accounts                  Account[]
  sessions                  Session[]
  auditLogs                 AuditLog[]           @relation("ActorAuditLogs")
  createdProjectChecklists  ProjectChecklist[]   @relation("ChecklistCreatedBy")
  updatedProjectChecklistItems ProjectChecklistItem[] @relation("ChecklistItemUpdatedBy")
  timeEntries               TimeEntry[]
  avvikRegistrert           Avvik[]              @relation("AvvikRegistrertAv")
  avvikLukket               Avvik[]              @relation("AvvikLukketAv")
  materialerLagtTil         MaterialItem[]       @relation("MaterialLagtTilAv")
  createdOffers             Offer[]              @relation("OfferCreatedBy")
  updatedOffers             Offer[]              @relation("OfferUpdatedBy")
  offerHistoryEntries       OfferHistory[]       @relation("OfferHistoryChangedBy")
  projectFinanceEntries     ProjectFinanceEntry[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())
  actor      User?    @relation("ActorAuditLogs", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([action])
  @@index([entityType])
  @@index([createdAt])
}

model Customer {
  id        String         @id @default(cuid())
  navn      String
  orgnr     String?
  epost     String
  telefon   String
  adresse   String
  postnr    String
  poststed  String
  notater   String?
  status    CustomerStatus @default(ACTIVE)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  projects  Project[]
  offers    Offer[]

  @@index([status])
  @@index([navn])
  @@index([telefon])
  @@index([epost])
}

model Project {
  id                   String             @id @default(cuid())
  customerId           String
  customer             Customer           @relation(fields: [customerId], references: [id], onDelete: Restrict)
  navn                 String
  beskrivelse          String?
  adresse              String?
  status               ProjectStatus      @default(PLANLAGT)
  billingType          ProjectBillingType @default(TIME)
  fastprisBelopEksMva Float?
  timeprisEksMva       Float?
  startDato            DateTime
  sluttDato            DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  checklists           ProjectChecklist[]
  timeEntries          TimeEntry[]
  avvik                Avvik[]
  materialer           MaterialItem[]
  offer                Offer?                 @relation("OfferToProject")
  financeEntries       ProjectFinanceEntry[]

  @@index([customerId])
  @@index([status])
  @@index([navn])
  @@index([billingType])
}

model TimeEntry {
  id               String   @id @default(cuid())
  projectId        String
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  dato             DateTime
  timer            Float
  beskrivelse      String?
  belopEksMva      Float
  fakturerbar      Boolean  @default(true)
  internKostPerTime Float?
  createdAt        DateTime @default(now())

  @@index([projectId])
  @@index([userId])
  @@index([dato])
  @@index([fakturerbar])
}

model ChecklistTemplate {
  id        String                  @id @default(cuid())
  navn      String
  kategori  String
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt
  items     ChecklistTemplateItem[]

  @@index([navn])
  @@index([kategori])
}

model ChecklistTemplateItem {
  id         String            @id @default(cuid())
  templateId String
  template   ChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  tekst      String
  rekkefolge Int

  @@index([templateId])
  @@index([rekkefolge])
}

model ProjectChecklist {
  id          String               @id @default(cuid())
  projectId   String
  project     Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  navn        String
  createdById String
  createdBy   User                 @relation("ChecklistCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt   DateTime             @default(now())
  items       ProjectChecklistItem[]

  @@index([projectId])
  @@index([createdById])
  @@index([createdAt])
}

model ProjectChecklistItem {
  id            String                    @id @default(cuid())
  checklistId   String
  checklist     ProjectChecklist          @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  tekst          String
  rekkefolge     Int
  svar           ChecklistItemAnswer?
  kommentar      String?
  updatedById    String?
  updatedBy      User?                    @relation("ChecklistItemUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  updatedAt      DateTime                 @updatedAt
  attachments    ChecklistItemAttachment[]

  @@index([checklistId])
  @@index([rekkefolge])
  @@index([updatedById])
}

model ChecklistItemAttachment {
  id              String               @id @default(cuid())
  checklistItemId String
  checklistItem   ProjectChecklistItem @relation(fields: [checklistItemId], references: [id], onDelete: Cascade)
  filUrl          String
  filType         String
  createdAt       DateTime             @default(now())

  @@index([checklistItemId])
}

model Avvik {
  id                 String                @id @default(cuid())
  projectId          String
  project            Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tittel             String
  beskrivelse        String
  alvorlighetsgrad   AvvikAlvorlighetsgrad
  status             AvvikStatus           @default(APENT)
  tiltak             String?
  registrertAvId     String
  registrertAv       User                  @relation("AvvikRegistrertAv", fields: [registrertAvId], references: [id], onDelete: Restrict)
  lukketAvId         String?
  lukketAv           User?                 @relation("AvvikLukketAv", fields: [lukketAvId], references: [id], onDelete: SetNull)
  lukketDato         DateTime?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  attachments        AvvikAttachment[]

  @@index([projectId])
  @@index([status])
  @@index([alvorlighetsgrad])
  @@index([registrertAvId])
  @@index([createdAt])
}

model AvvikAttachment {
  id        String   @id @default(cuid())
  avvikId   String
  avvik     Avvik    @relation(fields: [avvikId], references: [id], onDelete: Cascade)
  filUrl    String
  filType   String
  createdAt DateTime @default(now())

  @@index([avvikId])
}

model MaterialItem {
  id           String         @id @default(cuid())
  projectId    String
  project      Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  navn         String
  antall       Float
  enhet        String
  estimertPris Float?
  status       MaterialStatus @default(TRENGS)
  notat        String?
  lagtTilAvId  String
  lagtTilAv    User           @relation("MaterialLagtTilAv", fields: [lagtTilAvId], references: [id], onDelete: Restrict)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([projectId])
  @@index([status])
  @@index([lagtTilAvId])
}

model Offer {
  id                    String                   @id @default(cuid())
  customerId            String
  customer              Customer                 @relation(fields: [customerId], references: [id], onDelete: Restrict)
  projectId             String?                  @unique
  project               Project?                 @relation("OfferToProject", fields: [projectId], references: [id], onDelete: SetNull)
  navn                  String
  beskrivelse           String?
  offerType             OfferType
  status                OfferStatus              @default(UTKAST)
  timeEstimateHours     Float
  hourlyRateEksMva      Float
  materialCostEksMva    Float                    @default(0)
  markupPercent         Float                    @default(0)
  riskBufferPercent     Float                    @default(0)
  subtotalEksMva        Float
  markupAmountEksMva    Float
  riskAmountEksMva      Float
  totalEksMva           Float
  mvaPercent            Float                    @default(25)
  totalInkMva           Float
  createdById           String
  createdBy             User                     @relation("OfferCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedById           String
  updatedBy             User                     @relation("OfferUpdatedBy", fields: [updatedById], references: [id], onDelete: Restrict)
  sentAt                DateTime?
  approvedAt            DateTime?
  rejectedAt            DateTime?
  convertedToProjectAt  DateTime?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  specificationItems    OfferSpecificationItem[]
  history               OfferHistory[]

  @@index([customerId])
  @@index([status])
  @@index([offerType])
  @@index([createdById])
  @@index([updatedById])
  @@index([createdAt])
}

model OfferSpecificationItem {
  id           String   @id @default(cuid())
  offerId      String
  offer        Offer    @relation(fields: [offerId], references: [id], onDelete: Cascade)
  tekst        String
  rekkefolge   Int
  belopEksMva  Float?
  createdAt    DateTime @default(now())

  @@index([offerId])
  @@index([rekkefolge])
}

model OfferHistory {
  id           String             @id @default(cuid())
  offerId      String
  offer        Offer              @relation(fields: [offerId], references: [id], onDelete: Cascade)
  changedById  String
  changedBy    User               @relation("OfferHistoryChangedBy", fields: [changedById], references: [id], onDelete: Restrict)
  action       OfferHistoryAction
  fromStatus   OfferStatus?
  toStatus     OfferStatus?
  note         String?
  snapshot     Json?
  createdAt    DateTime           @default(now())

  @@index([offerId])
  @@index([changedById])
  @@index([createdAt])
}

model ProjectFinanceEntry {
  id           String                @id @default(cuid())
  projectId    String
  project      Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type         ProjectFinanceEntryType
  dato         DateTime
  beskrivelse  String
  belopEksMva  Float
  createdById  String
  createdBy    User                  @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdAt    DateTime              @default(now())

  @@index([projectId])
  @@index([type])
  @@index([dato])
  @@index([createdById])
}
