generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  EMPLOYEE
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
}

enum ProjectStatus {
  PLANLAGT
  PAGAR
  FERDIG
  FAKTURERT
}

enum ProjectBillingType {
  TIME
  FASTPRIS
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         Role      @default(EMPLOYEE)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  accounts     Account[]
  sessions     Session[]
  auditLogs    AuditLog[] @relation("ActorAuditLogs")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())
  actor      User?    @relation("ActorAuditLogs", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([action])
  @@index([entityType])
  @@index([createdAt])
}

model Customer {
  id        String         @id @default(cuid())
  navn      String
  orgnr     String?
  epost     String
  telefon   String
  adresse   String
  postnr    String
  poststed  String
  notater   String?
  status    CustomerStatus @default(ACTIVE)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  projects  Project[]

  @@index([status])
  @@index([navn])
  @@index([telefon])
  @@index([epost])
}

model Project {
  id                 String             @id @default(cuid())
  customerId         String
  customer           Customer           @relation(fields: [customerId], references: [id], onDelete: Restrict)
  navn               String
  beskrivelse        String?
  adresse            String?
  status             ProjectStatus      @default(PLANLAGT)
  billingType        ProjectBillingType @default(TIME)
  fastprisBelopEksMva Float?
  timeprisEksMva     Float?
  startDato          DateTime
  sluttDato          DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([customerId])
  @@index([status])
  @@index([navn])
  @@index([billingType])
}


